# =============================================================================
# Configuration Firebase — FICHIER DE RÉFÉRENCE (à committer sans vraies clés)
# =============================================================================
# NOTE IMPORTANTE : ce projet est un site statique SANS étape de build. Le
# navigateur ne lit donc PAS de fichier .env. Ces variables servent de
# référence ; les valeurs réelles doivent être reportées dans
#   js/firebase-config.js   (copié depuis js/firebase-config.example.js)
# qui est ignoré par git.
#
# Rappel : la configuration web Firebase n'est pas un secret (elle identifie
# le projet côté client et reste visible dans le navigateur). La vraie
# sécurité passe par les règles Firestore (voir firestore.rules) et la
# restriction de la clé d'API aux domaines autorisés dans Google Cloud.
# =============================================================================

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
